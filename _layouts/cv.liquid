<!-- Updated Contact Information section -->
{% if cv.name or cv.label or cv.location or cv.email or cv.phone or cv.website %}
  <div class="card mt-3 p-3">
    <div class="d-flex align-items-center justify-content-between flex-wrap">
      
      <!-- Contact Details (Left-aligned, no labels) -->
      <div style="flex: 1; min-width: 250px;">
        <h4 class="card-title font-weight-bold mb-2">{{ cv.name }}</h4>
        <div class="font-weight-light" style="line-height: 1.6;">
          {% if cv.label %}<div>{{ cv.label }}</div>{% endif %}
          {% if cv.email %}<div>{{ cv.email }}</div>{% endif %}
          {% if cv.phone %}<div>{{ cv.phone }}</div>{% endif %}
          {% if cv.address %}
            <div>
              {% if cv.address.city %}{{ cv.address.city }}{% endif %}
              {% if cv.address.region %}{{ cv.address.region }}{% endif %}
            </div>
          {% endif %}
          {% if cv.website %}
            <div><a href="{{ cv.website }}" target="_blank">{{ cv.website | replace: 'https://', '' | replace: 'http://', '' }}</a></div>
          {% endif %}
        </div>
      </div>

      <!-- Profile Photo (Right-aligned, circular) -->
      <div class="ml-3">
        <img src="{{ '/assets/img/profile.jpg' | relative_url }}" 
             alt="Profile Photo" 
             class="rounded-circle" 
             style="width: 120px; height: 120px; object-fit: cover; border: 2px solid #f8f9fa;">
      </div>

    </div>
  </div>
{% endif %}
