---
layout: default
---
{% comment %}
  Unified CV layout that handles both RenderCV (YAML) and JSONResume (JSON) formats
  - Decreased card title font size using h4.h5 classes.
  - Ensured generic loop fallbacks right-align dates.
{% endcomment %}

<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {{ page.title }}
      {% if page.cv_pdf %}
        <a
          {% if page.cv_pdf contains '://' %}
            href="{{ page.cv_pdf }}"
          {% else %}
            href="{{ page.cv_pdf | relative_url }}"
          {% endif %}
          target="_blank"
          rel="noopener noreferrer"
          class="float-right"
        >
          <i class="fa-solid fa-file-pdf"></i>
        </a>
      {% endif %}
    </h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% comment %} Determine which CV format to render {% endcomment %}
      {% assign render_rendercv = false %}
      {% assign render_jsonresume = false %}

      {% if page.cv_format == 'rendercv' %}
        {% assign render_rendercv = true %}
      {% elsif page.cv_format == 'jsonresume' %}
        {% assign render_jsonresume = true %}
      {% else %}
        {% comment %} Legacy behavior: RenderCV takes priority if both exist {% endcomment %}
        {% if site.data.cv and site.data.cv.cv %}
          {% assign render_rendercv = true %}
        {% elsif site.data.resume %}
          {% assign render_jsonresume = true %}
        {% endif %}
      {% endif %}

      {% if render_rendercv and site.data.cv and site.data.cv.cv %}
        {% comment %} RenderCV format {% endcomment %}
        {% assign cv = site.data.cv.cv %}

        <!-- Header/Contact Information -->
        {% if cv.name or cv.label or cv.location or cv.email or cv.phone or cv.website %}
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Contact Information</h4>
            <table class="table table-cv table-sm table-borderless mb-0 lh-sm" style="line-height: 1.2;">
              {% if cv.name %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Name</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ cv.name }}</td>
                </tr>
              {% endif %}
              {% if cv.label %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Professional Title</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ cv.label }}</td>
                </tr>
              {% endif %}
              {% if cv.email %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Email</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ cv.email }}</td>
                </tr>
              {% endif %}
              {% if cv.phone %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Phone</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ cv.phone }}</td>
                </tr>
              {% endif %}
              {% if cv.address %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Location</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">
                    {% if cv.address.street %}{{ cv.address.street }}, {% endif %}
                    {% if cv.address.city %}{{ cv.address.city }}, {% endif %}
                    {% if cv.address.region %}{{ cv.address.region }} {% endif %}
                    {% if cv.address.postalCode %}{{ cv.address.postalCode }}{% endif %}
                  </td>
                </tr>
              {% endif %}
              {% if cv.website %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Website</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">
                    <a href="{{ cv.website }}" target="_blank">{{ cv.website }}</a>
                  </td>
                </tr>
              {% endif %}
            </table>
          </div>
        {% endif %}

        <!-- Summary -->
        {% if cv.summary %}
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Professional Summary</h4>
            <p class="mb-0 lh-sm" style="line-height: 1.3;">{{ cv.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
          </div>
        {% endif %}

        <!-- RenderCV Sections: Forced Education First -->
        {% if cv.sections.Education %}
          <a class="anchor" id="education"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Education</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = cv.sections.Education %}
              {% include cv/education.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- RenderCV Sections: Combined Experience Second -->
        {% assign empty_array = '' | split: ',' %}
        {% assign exp = cv.sections.Experience | default: empty_array %}
        {% assign vol = cv.sections.Volunteer | default: empty_array %}
        {% assign combined_experience = exp | concat: vol %}
        {% if combined_experience.size > 0 %}
          <a class="anchor" id="experience"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Experience</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = combined_experience %}
              {% include cv/experience.liquid %}
            </div>
          </div>
        {% endif %}

        {% comment %} Now render all remaining loops dynamically, skipping Education, Experience, and Volunteer {% endcomment %}
        {% for section_pair in cv.sections %}
          {% assign section_title = section_pair[0] %}
          {% assign section_entries = section_pair[1] %}

          {% if section_title == 'Education' or section_title == 'Experience' or section_title == 'Volunteer' %}
            {% continue %}
          {% endif %}

          <a class="anchor" id="{{ section_title | slugify }}"></a>
          <div class="card mt-3 p-3">
            <div class="d-flex justify-content-between align-items-baseline mb-2">
              <h4 class="card-title font-weight-medium h5 m-0">{{ section_title }}</h4>
            </div>
            <div class="lh-sm" style="line-height: 1.3;">
              {% if section_title == 'Awards' or section_title == 'Honors and Awards' %}
                {% assign entries = section_entries %}
                {% include cv/awards.liquid %}
              {% elsif section_title == 'Publications' %}
                {% assign entries = section_entries %}
                {% include cv/publications.liquid %}
              {% elsif section_title == 'Skills' %}
                {% assign entries = section_entries %}
                {% include cv/skills.liquid %}
              {% elsif section_title == 'Languages' %}
                {% assign entries = section_entries %}
                {% include cv/languages.liquid %}
              {% elsif section_title == 'Interests' or section_title == 'Academic Interests' %}
                {% assign entries = section_entries %}
                {% include cv/interests.liquid %}
              {% elsif section_title == 'Certificates' %}
                {% assign entries = section_entries %}
                {% include cv/certificates.liquid %}
              {% elsif section_title == 'Projects' or section_title == 'Open Source Projects' %}
                {% assign entries = section_entries %}
                {% include cv/projects.liquid %}
              {% elsif section_title == 'References' %}
                {% assign entries = section_entries %}
                {% include cv/references.liquid %}
              {% else %}
                <!-- Generic section -->
                {% for entry in section_entries %}
                  {% if entry.bullet %}
                    <ul class="card-text font-weight-light list-group list-group-flush mb-1">
                      <li class="list-group-item py-05">{{ entry.bullet | markdownify | remove: '<p>' | remove: '</p>' }}</li>
                    </ul>
                  {% elsif entry.label %}
                    <div class="card-text font-weight-light d-flex justify-content-between py-05">
                      <span><strong>{{ entry.label }}:</strong> {{ entry.details }}</span>
                      {% if entry.date %}<span class="text-right text-muted font-weight-normal">{{ entry.date }}</span>{% endif %}
                    </div>
                  {% endif %}
                {% endfor %}
              {% endif %}
            </div>
          </div>
        {% endfor %}

      {% elsif render_jsonresume and site.data.resume %}
        {% comment %} JSONResume format {% endcomment %}

        <!-- Contact Information -->
        {% if site.data.resume.basics %}
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Contact Information</h4>
            {% assign basics = site.data.resume.basics %}
            <table class="table table-cv table-sm table-borderless mb-0 lh-sm" style="line-height: 1.2;">
              {% if basics.name %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Name</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ basics.name }}</td>
                </tr>
              {% endif %}
              {% if basics.label %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Professional Title</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ basics.label }}</td>
                </tr>
              {% endif %}
              {% if basics.email %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Email</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ basics.email }}</td>
                </tr>
              {% endif %}
              {% if basics.phone %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Phone</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">{{ basics.phone }}</td>
                </tr>
              {% endif %}
              {% if basics.location %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Location</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">
                    {% if basics.location.address %}{{ basics.location.address }}, {% endif %}
                    {% if basics.location.city %}{{ basics.location.city }}, {% endif %}
                    {% if basics.location.region %}{{ basics.location.region }} {% endif %}
                    {% if basics.location.postalCode %}{{ basics.location.postalCode }}{% endif %}
                  </td>
                </tr>
              {% endif %}
              {% if basics.url %}
                <tr>
                  <td class="p-0 py-1 pr-2 font-weight-bold"><b>Website</b></td>
                  <td class="p-0 py-1 pl-2 font-weight-light">
                    <a href="{{ basics.url }}" target="_blank">{{ basics.url }}</a>
                  </td>
                </tr>
              {% endif %}
            </table>
          </div>
        {% endif %}

        <!-- Summary -->
        {% if site.data.resume.basics.summary %}
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Professional Summary</h4>
            <p class="mb-0 lh-sm" style="line-height: 1.3;">{{ site.data.resume.basics.summary | markdownify | remove: '<p>' | remove: '</p>' }}</p>
          </div>
        {% endif %}

        <!-- JSONResume Sections: Education First -->
        {% if site.data.resume.education.size > 0 %}
          <a class="anchor" id="education"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Education</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.education %}
              {% include cv/education.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- JSONResume Sections: Experience Second -->
        {% assign empty_array = '' | split: ',' %}
        {% assign work = site.data.resume.work | default: empty_array %}
        {% assign vol = site.data.resume.volunteer | default: empty_array %}
        {% assign combined_experience = work | concat: vol %}
        {% if combined_experience.size > 0 %}
          <a class="anchor" id="experience"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Experience</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = combined_experience %}
              {% include cv/experience.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Awards -->
        {% if site.data.resume.awards.size > 0 %}
          <a class="anchor" id="awards"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Awards</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.awards %}
              {% include cv/awards.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Publications -->
        {% if site.data.resume.publications.size > 0 %}
          <a class="anchor" id="publications"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Publications</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.publications %}
              {% include cv/publications.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Skills -->
        {% if site.data.resume.skills.size > 0 %}
          <a class="anchor" id="skills"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Skills</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.skills %}
              {% include cv/skills.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Languages -->
        {% if site.data.resume.languages.size > 0 %}
          <a class="anchor" id="languages"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Languages</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.languages %}
              {% include cv/languages.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Interests -->
        {% if site.data.resume.interests.size > 0 %}
          <a class="anchor" id="interests"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Interests</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.interests %}
              {% include cv/interests.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Certificates -->
        {% if site.data.resume.certificates.size > 0 %}
          <a class="anchor" id="certificates"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Certificates</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.certificates %}
              {% include cv/certificates.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- Projects -->
        {% if site.data.resume.projects.size > 0 %}
          <a class="anchor" id="projects"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">Projects</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.projects %}
              {% include cv/projects.liquid %}
            </div>
          </div>
        {% endif %}

        <!-- References -->
        {% if site.data.resume.references.size > 0 %}
          <a class="anchor" id="references"></a>
          <div class="card mt-3 p-3">
            <h4 class="card-title font-weight-medium h5 mb-2">References</h4>
            <div class="lh-sm" style="line-height: 1.3;">
              {% assign entries = site.data.resume.references %}
              {% include cv/references.liquid %}
            </div>
          </div>
        {% endif %}

      {% else %}
        <p>No CV data found. Please configure either RenderCV (cv.yml) or JSONResume (resume.json) data.</p>
      {% endif %}
    </div>
  </article>
</div>
