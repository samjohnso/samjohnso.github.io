---
layout: default
---

<div class="post">
  <header class="post-header">
    <!-- Tweak 3: Forcing the main page title header to lowercase "teaching" -->
    <h1 class="post-title" style="text-transform: lowercase;">{{ page.title }}</h1>
    {% if page.description %}
      <p class="post-description">{{ page.description }}</p>
    {% endif %}
  </header>

  <article>
    <div class="cv">
      {% if site.data.teaching.sections %}
        {% assign sections = site.data.teaching.sections %}

        {% for section_pair in sections %}
          {% assign section_title = section_pair[0] %}
          {% assign section_entries = section_pair[1] %}

          <a class="anchor" id="{{ section_title | slugify }}"></a>
          
          <div class="card mt-2 p-2">
            <h4 class="card-title font-weight-medium mb-2 px-1" style="font-size: 1.25rem;">{{ section_title }}</h4>
            <div>
              <ul class="card-text font-weight-light list-group list-group-flush">
                {% for entry in section_entries %}
                  
                  <li class="list-group-item py-1 px-1">
                    <div class="d-flex justify-content-between align-items-center flex-wrap">
                      
                      <!-- Left column: Primary course details -->
                      <div style="flex: 1; min-width: 250px;">
                        {% if entry.title %}
                          <span class="font-weight-bold" style="font-size: 0.95rem;">{{ entry.title }}</span>
                        {% endif %}

                        {% if entry.code %}
                          <span class="text-monospace ml-1" style="font-size: 0.8rem; background: #e9ecef; padding: 1px 5px; border-radius: 4px; color: #495057;">{{ entry.code }}</span>
                        {% endif %}

                        {% if entry.institution %}
                          <span class="text-muted small ml-2">• {{ entry.institution }}</span>
                        {% endif %}

                        <!-- Tweak 2: Added optional Course Materials PDF button line -->
                        {% if entry.pdf %}
                          <div class="mt-1">
                            <!-- Styled directly with theme variables to dynamically match light/dark modes -->
                            <a href="{{ entry.pdf | relative_url }}" 
                               class="btn btn-sm py-0 px-2 font-weight-normal custom-pdf-btn" 
                               style="font-size: 0.75rem; border-radius: 4px; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); background: transparent;" 
                               target="_blank" 
                               rel="noopener noreferrer">
                              <i class="fas fa-file-pdf mr-1"></i>Course Materials
                            </a>
                          </div>
                        {% endif %}

                        {% if entry.notes %}
                          <small class="text-secondary d-block mt-0"><em>{{ entry.notes }}</em></small>
                        {% endif %}

                        {% if entry.mentor %}
                          <small class="text-secondary d-block mt-0"><em>with {{ entry.mentor }}</em></small>
                        {% endif %}
                        {% if entry.year %}
                          <div class="text-right my-1" style="min-width: 80px; flex-shrink: 0; margin-left: 10px;">
                            <span class="badge badge-light py-1 px-2" style="font-size: 0.8rem; white-space: normal; border: 1px solid #dee2e6; background-color: #f8f9fa; color: #495057;">
                              {{ entry.year }}
                            </span>
                          </div>
                        {% endif %}
                      </div>

                      <!-- Right column: Terms aligned on the edge -->
                      {% if entry.terms %}
                        <div class="text-right my-1">
                          <!-- Tweak 1: Changed border to a matching subtle grey (#dee2e6) -->
                          <span class="badge badge-light py-1 px-2" style="font-size: 0.8rem; white-space: normal; border: 1px solid #dee2e6; background-color: #f8f9fa; color: #495057;">{{ entry.terms }}</span>
                        </div>
                      {% endif %}

                    </div>
                  </li>
                  
                {% endfor %}
              </ul>
            </div>
          </div>
        {% endfor %}

      {% else %}
        <p>No teaching data found. Please configure _data/teaching.yml</p>
      {% endif %}
    </div>
  </article>
</div>
