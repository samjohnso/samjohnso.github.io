{% comment %}
  Unified publications entry renderer,
  styled to match the teaching, education, and experience page layouts.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item py-1 px-1">
      
      {% comment %} Date extraction logic {% endcomment %}
      {% capture pub_date %}
        {% if entry.releaseDate %}{{ entry.releaseDate }}{% elsif entry.date %}{{ entry.date }}{% endif %}
      {% endcapture %}

      {% if pub_date != '' %}
        {% assign date_string = pub_date | split: '-' | first %}
      {% else %}
        {% assign date_string = null %}
      {% endif %}

      {% assign entry_authors = entry.author | default: entry.authors %}

      <div class="d-flex justify-content-between align-items-center flex-wrap">
        
        <!-- Left column: Arrow and Primary publication details -->
        <div class="d-flex align-items-start" style="flex: 1; min-width: 250px;">
          
          <!-- Abstract Dropdown Arrow Container -->
          <div style="width: 20px; flex-shrink: 0; margin-top: 3px;">
            {% if entry.summary %}
              <button class="btn btn-link p-0 m-0 shadow-none text-decoration-none" 
                      style="font-size: 0.95rem; color: var(--global-theme-color); line-height: 1;" 
                      type="button" 
                      data-toggle="collapse" 
                      data-target="#summary-{{ forloop.index }}" 
                      aria-expanded="false" 
                      aria-controls="summary-{{ forloop.index }}">
                <i class="fas fa-caret-down"></i>
              </button>
            {% endif %}
          </div>

          <!-- Publication Text Content -->
          <div>
            <!-- Title -->
            <span class="font-weight-bold" style="font-size: 0.95rem;">
              {% if entry.url %}
                <a href="{{ entry.url }}">{{ entry.title | default: entry.name }}</a>
              {% else %}
                {{ entry.title | default: entry.name }}
              {% endif %}
            </span>

            <!-- Authors -->
            {% if entry_authors %}
              <span class="text-muted small ml-2">• {{ entry_authors }}</span>
            {% endif %}

            <!-- Publisher/Journal -->
            {% if entry.publisher %}
              <span class="text-muted small ml-2"><em>• {{ entry.publisher }}</em></span>
            {% endif %}
          </div>

        </div>

        <!-- Right column: Date aligned on the edge as a badge -->
        {% if date_string %}
          <div class="text-right my-1">
            <span class="badge badge-light py-1 px-2" style="font-size: 0.8rem; white-space: normal; border: 1px solid #dee2e6; background-color: #f8f9fa; color: #495057;">
              {{ date_string }}
            </span>
          </div>
        {% endif %}

      </div>

      <!-- Optional Summary/Abstract Block (Collapsible) -->
      {% if entry.summary %}
        <div class="collapse mt-2 pl-4" id="summary-{{ forloop.index }}">
          <div style="font-size: 0.95rem; line-height: 1.35; color: #495057;">
            {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
          </div>
        </div>
      {% endif %}

    </li>
  {% endfor %}
</ul>
