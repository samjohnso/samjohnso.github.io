{% comment %}
  Unified work/experience entry renderer for both RenderCV and JSONResume formats,
  styled to match the teaching and education page layout.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item py-1 px-1">
      
      {% comment %} Date extraction logic {% endcomment %}
      {% capture start_date %}
        {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
      {% endcapture %}
      {% capture end_date %}
        {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
      {% endcapture %}

      {% if start_date != '' %}
        {% assign startDate = start_date | split: '-' | first %}
        {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
        {% assign date_string = startDate | append: ' - ' | append: endDate %}
      {% else %}
        {% assign date_string = null %}
      {% endif %}

      {% capture location %}{% if entry.location %}{{ entry.location }}{% endif %}{% endcapture %}
      {% capture position_title %}{% if entry.position %}{{ entry.position }}{% endif %}{% endcapture %}
      
      {% capture company_name %}
        {% if entry.name %}{{ entry.name }}{% elsif entry.company %}{{ entry.company }}{% elsif entry.organization %}{{ entry.organization }}{% endif %}
      {% endcapture %}

      <div class="d-flex justify-content-between align-items-center flex-wrap">
        
        <!-- Left column: Arrow and Primary experience details -->
        <div class="d-flex align-items-start" style="flex: 1; min-width: 250px;">
          
          <!-- Dropdown Arrow Container -->
          <div style="width: 20px; flex-shrink: 0; margin-top: 0px; margin-right: 4px;">
            {% if entry.summary or entry.highlights %}
              <button class="btn btn-link p-0 m-0 shadow-none text-decoration-none" 
                      style="font-size: 0.95rem; color: var(--global-theme-color); line-height: 1; cursor: pointer;" 
                      type="button" 
                      data-toggle="collapse" 
                      data-target="#experience-{{ forloop.index }}" 
                      aria-expanded="false" 
                      aria-controls="experience-{{ forloop.index }}">
                <i class="fas fa-caret-down"></i>
              </button>
            {% endif %}
          </div>

          <!-- Experience Text Content -->
          <div>
            <!-- Position Title -->
            <span class="font-weight-bold" style="font-size: 0.95rem;">
              {% if entry.url %}
                <a href="{{ entry.url }}">{{ position_title }}</a>
              {% elsif position_title != '' %}
                {{ position_title }}
              {% endif %}
            </span>

            <!-- Company / Organization (Matches Education styling) -->
            {% if company_name != '' %}
              <span class="text-muted small ml-2">• {{ company_name }}</span>
            {% endif %}

            <!-- Location -->
            {% if location != '' %}
              <span class="text-muted small ml-2">• <i class="fa-solid fa-location-dot" style="margin-right: 3px; opacity: 0.7;"></i>{{ location }}</span>
            {% endif %}
          </div>

        </div>

        <!-- Right column: Dates aligned on the edge as a badge -->
        {% if date_string %}
          <div class="text-right my-1">
            <span class="badge badge-light py-1 px-2" style="font-size: 0.8rem; white-space: normal; border: 1px solid #dee2e6; background-color: #f8f9fa; color: #495057;">
              {{ date_string }}
            </span>
          </div>
        {% endif %}

      </div>

      <!-- Collapsible Description Block (Contains both Summary and Highlights) -->
      {% if entry.summary or entry.highlights %}
        <div class="collapse" id="experience-{{ forloop.index }}">
          
          <!-- Optional Summary Block with a bullet point and tighter margin -->
          {% if entry.summary %}
            <ul class="items mt-1 mb-0 pl-4" style="line-height: 1.35;">
              <li style="margin-bottom: 0.15rem;">
                <span class="item" style="font-size: 0.95rem; font-style: italic;">
                  {{ entry.summary | markdownify | remove: '<p>' | remove: '</p>' }}
                </span>
              </li>
            </ul>
          {% endif %}

          <!-- Highlights (Bullet points) styled tighter -->
          {% if entry.highlights %}
            <ul class="items {% if entry.summary %}mt-0{% else %}mt-1{% endif %} mb-1 pl-4" style="line-height: 1.35;">
              {% for item in entry.highlights %}
                <li style="margin-bottom: 0.15rem;"><span class="item small">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span></li>
              {% endfor %}
            </ul>
          {% endif %}

        </div>
      {% endif %}

    </li>
  {% endfor %}
</ul>
