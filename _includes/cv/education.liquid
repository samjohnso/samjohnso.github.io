{% comment %}
  Unified education entry renderer for both RenderCV and JSONResume formats
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item" style="padding-top: 0.6rem; padding-bottom: 0.6rem;">
      <div class="row">
        
        {% comment. Date logic remains the same, but positioning has moved to the right side below {% endcomment %}
        {% capture start_date %}
          {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
        {% endcapture %}
        {% capture end_date %}
          {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
        {% endcapture %}

        {% if start_date != '' %}
          {% assign startDate = start_date | split: '-' | first %}
          {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
          {% assign date_string = startDate | append: ' - ' | append: endDate %}
        {% else %}
          {% assign date_string = null %}
        {% endif %}

        {% capture location %}{% if entry.location %}{{ entry.location }}{% endif %}{% endcapture %}
        {% capture study_type %}{% if entry.studyType %}{{ entry.studyType }}{% elsif entry.degree %}{{ entry.degree }}{% endif %}{% endcapture %}

        <!-- Main text layout spans the full width to allow clean right-alignment -->
        <div class="col-xs-12 col-sm-12 col-md-12">
          
          <!-- Top Row: Degree/Area on left, Date on right -->
          <div class="d-flex justify-content-between align-items-baseline ml-1 ml-md-4" style="margin-bottom: 0.15rem;">
            <h6 class="title font-weight-bold mb-0" style="font-size: 1.05rem;">
              {% if entry.url %}
                <a href="{{ entry.url }}">{{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}</a>
              {% else %}
                {{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}
              {% endif %}
            </h6>
            {% if date_string %}
              <span class="text-muted small font-weight-normal text-right" style="white-space: nowrap;">
                {{ date_string }}
              </span>
            {% endif %}
          </div>

          <!-- Second Row: Institution on left, Location on right -->
          <div class="d-flex justify-content-between align-items-baseline ml-1 ml-md-4" style="margin-bottom: 0.2rem; line-height: 1.3;">
            <div class="text-secondary" style="font-size: 0.95rem; font-weight: 500;">
              {{ entry.institution }}
            </div>
            {% if location != '' %}
              <span class="text-muted small text-right" style="font-size: 0.85rem;">
                <i class="fa-solid fa-location-dot" style="margin-right: 3px; opacity: 0.7;"></i>{{ location }}
              </span>
            {% endif %}
          </div>

          <!-- Conditional Row: Thesis PDF Button (appears if entry has thesis_pdf variable) -->
          {% if entry.thesis_pdf %}
            <div class="ml-1 ml-md-4" style="margin-bottom: 0.25rem; margin-top: 0.25rem;">
              <a href="{{ entry.thesis_pdf }}" target="_blank" rel="noopener noreferrer" class="btn btn-sm p-1 px-2 m-0 align-baseline" style="font-size: 0.75rem; border: 1px solid #ced4da; background-color: #f8f9fa; color: #495057; border-radius: 4px; text-transform: none; box-shadow: none;">
                <i class="fa-solid fa-file-pdf text-danger" style="margin-right: 5px;"></i>Thesis
              </a>
            </div>
          {% endif %}

          <!-- Courses & Highlights blocks styled tighter -->
          {% if entry.courses or entry.highlights %}
            <ul class="items" style="margin-top: 0.25rem; margin-bottom: 0; padding-left: 1.2rem; line-height: 1.35;">
              {% for item in entry.courses %}
                <li style="margin-bottom: 0.15rem;"><span class="item small">{{ item }}</span></li>
              {% endfor %}
              {% for item in entry.highlights %}
                <li style="margin-bottom: 0.15rem;"><span class="item small">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span></li>
              {% endfor %}
            </ul>
          {% endif %}

        </div>
      </div>
    </li>
  {% endfor %}
</ul>
