{% comment %}
  Unified education entry renderer for both RenderCV and JSONResume formats,
  styled to match the teaching page layout.
{% endcomment %}

<ul class="card-text font-weight-light list-group list-group-flush">
  {% for entry in entries %}
    <li class="list-group-item py-1 px-1">
      
      {% comment %} Date logic {% endcomment %}
      {% capture start_date %}
        {% if entry.start_date %}{{ entry.start_date }}{% elsif entry.startDate %}{{ entry.startDate }}{% endif %}
      {% endcapture %}
      {% capture end_date %}
        {% if entry.end_date %}{{ entry.end_date }}{% elsif entry.endDate %}{{ entry.endDate }}{% endif %}
      {% endcapture %}

      {% if start_date != '' %}
        {% assign startDate = start_date | split: '-' | first %}
        {% assign endDate = end_date | split: '-' | first | default: 'Present' %}
        {% assign date_string = startDate | append: ' - ' | append: endDate %}
      {% else %}
        {% assign date_string = null %}
      {% endif %}

      {% capture location %}{% if entry.location %}{{ entry.location }}{% endif %}{% endcapture %}
      {% capture study_type %}{% if entry.studyType %}{{ entry.studyType }}{% elsif entry.degree %}{{ entry.degree }}{% endif %}{% endcapture %}

      <div class="d-flex justify-content-between align-items-center flex-wrap">
        
        <!-- Left column: Primary education details -->
        <div style="flex: 1; min-width: 250px;">
          
          <!-- Degree / Area -->
          <span class="font-weight-bold" style="font-size: 0.95rem;">
            {% if entry.url %}
              <a href="{{ entry.url }}">{{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}</a>
            {% else %}
              {{ study_type }}{% if entry.area %} in {{ entry.area }}{% endif %}
            {% endif %}
          </span>

          <!-- Institution -->
          {% if entry.institution %}
            <span class="text-muted small ml-2">• {{ entry.institution }}</span>
          {% endif %}

          <!-- Location -->
          {% if location != '' %}
            <span class="text-muted small ml-2">• <i class="fa-solid fa-location-dot" style="margin-right: 3px; opacity: 0.7;"></i>{{ location }}</span>
          {% endif %}

          <!-- Thesis PDF button styled dynamically with theme variables -->
          {% if entry.thesis_pdf %}
            <div class="mt-1">
              <a href="{{ entry.thesis_pdf | relative_url }}" 
                 class="btn btn-sm py-0 px-2 font-weight-normal custom-pdf-btn" 
                 style="font-size: 0.75rem; border-radius: 4px; color: var(--global-theme-color); border: 1px solid var(--global-theme-color); background: transparent;" 
                 target="_blank" 
                 rel="noopener noreferrer">
                <i class="fas fa-file-pdf mr-1"></i>Thesis
              </a>
            </div>
          {% endif %}

        </div>

        <!-- Right column: Dates aligned on the edge as a badge -->
        {% if date_string %}
          <div class="text-right my-1">
            <span class="badge badge-light py-1 px-2" style="font-size: 0.8rem; white-space: normal; border: 1px solid #dee2e6; background-color: #f8f9fa; color: #495057;">
              {{ date_string }}
            </span>
          </div>
        {% endif %}

      </div>

      <!-- Courses & Highlights blocks (drops below the main flex row) -->
      {% if entry.courses or entry.highlights %}
        <ul class="items mt-2 mb-1 pl-4" style="line-height: 1.35;">
          {% for item in entry.courses %}
            <li style="margin-bottom: 0.15rem;"><span class="item small">{{ item }}</span></li>
          {% endfor %}
          {% for item in entry.highlights %}
            <li style="margin-bottom: 0.15rem;"><span class="item small">{{ item | markdownify | remove: '<p>' | remove: '</p>' }}</span></li>
          {% endfor %}
        </ul>
      {% endif %}

    </li>
  {% endfor %}
</ul>
